#Порт HTTP сервера
HTTP_PORT=1111

#Тип среды(local, dev, prod)
ENV_TYPE=local

#Для БД
DATABASE_USER=<имя пользователя>
DATABASE_PASSWORD=<пароль>
DATABASE_NAME=<имя базы данных>
DATABASE_HOST=database
DATABASE_PORT=1111

#Таймауты
READ_TIMEOUT=1(в секундах)
WRITE_TIMEOUT=11(в секундах)
IDLE_TIMEOUT=111(в секундах)
SHUTDOWN_CTX_TIMEOUT=1(в секундах)

#Elasticsearch
ES_PORT=2222
ES_SEARCH_SIZE=11(в штуках)

#Путь до данных(.csv файла)
DATA_PATH=./data/posts.csv